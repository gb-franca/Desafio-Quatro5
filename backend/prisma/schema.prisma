// ==========================================
// @file schema.prisma
// @description Definição do esquema do banco de dados (Prisma) para o TaskFlow.
//              Mapeia os modelos User e Task no SQLite.
// @version 1.0.0
// @date 2026-06-14
// @history
//  - 1.0.0 (2026-06-14): Criação das tabelas User e Task com relacionamentos.
// ==========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

/// Representa um membro da equipe responsável por executar tarefas no Kanban.
model User {
  id        String   @id @default(uuid()) // Identificador único gerado automaticamente (UUID)
  name      String                        // Nome completo do usuário
  role      String                        // Cargo/Função desempenhada (ex: Dev, Designer)
  initials  String                        // Iniciais do nome para exibição em avatares (ex: JD, AB)
  tasks     Task[]                        // Relação com as tarefas atribuídas ao usuário
  createdAt DateTime @default(now())      // Data e hora de criação do cadastro
}

/// Representa uma atividade cadastrada no quadro Kanban.
model Task {
  id          String   @id @default(uuid()) // Identificador único da tarefa (UUID)
  title       String                        // Título/Descrição da atividade
  area        String                        // Área de atuação da tarefa (ex: DESIGN, FRONTEND, QA)
  status      String   @default("BACKLOG")  // Status do fluxo: BACKLOG, DOING, REVIEW ou DONE
  dueDate     DateTime                      // Data limite para conclusão da tarefa
  
  // Relacionamento opcional com User (uma tarefa pode estar sem responsável)
  assignee    User?    @relation(fields: [assigneeId], references: [id])
  assigneeId  String?

  createdAt   DateTime @default(now())      // Registro de criação da tarefa
  updatedAt   DateTime @updatedAt           // Atualização automática ao modificar a tarefa
}
